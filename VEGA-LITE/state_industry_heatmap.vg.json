  "layer": [
    {
      "params": [
        {
          "name": "cell_hover",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout"
          }
        }
      ],
      "mark": {
        "type": "rect"
      },
      "encoding": {
        "x": {
          "field": "state",
          "type": "nominal",
          "title": null,
          "sort": [
            "ACT",
            "VIC",
            "NSW",
            "QLD",
            "WA",
            "SA",
            "TAS",
            "NT"
          ]
        },
        "y": {
          "field": "industry",
          "type": "nominal",
          "title": null,
          "sort": [
            "Services",
            "Retail trade",
            "Distribution",
            "Construction",
            "Agriculture",
            "Health and education",
            "Hospitality",
            "Manufacturing"
          ],
          "axis": {
            "labelLimit": 160
          }
        },
        "color": {
          "field": "adoption_pct",
          "type": "quantitative",
          "title": "Est. adoption (%)",
          "scale": {
            "domain": [
              30,
              100
            ],
            "range": [
              "#f7f0ee",
              "#de1e1c"
            ]
          },
          "legend": {
            "orient": "right",
            "direction": "vertical",
            "gradientLength": 120,
            "titleFontSize": 9,
            "labelFontSize": 9,
            "labelExpr": "datum.value + '%'"
          }
        },
        "opacity": {
          "condition": {
            "param": "cell_hover",
            "empty": true,
            "value": 1
          },
          "value": 0.5
        },
        "stroke": {
          "condition": {
            "param": "cell_hover",
            "empty": false,
            "value": "#1a1814"
          },
          "value": "transparent"
        },
        "strokeWidth": {
          "condition": {
            "param": "cell_hover",
            "empty": false,
            "value": 2
          },
          "value": 0
        },
        "tooltip": [
          {
            "field": "state",
            "title": "State"
          },
          {
            "field": "industry",
            "title": "Industry"
          },
          {
            "field": "adoption_pct",
            "title": "Est. AI adoption (%)",
            "format": ".0f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 8.5
      },
      "encoding": {
        "x": {
          "field": "state",
