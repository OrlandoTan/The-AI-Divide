        "year": "2028",
        "adoption": 0.515,
        "growth": 0.055
      }
    ]
  },
  "transform": [
    {
      "calculate": "datum.growth >= 0.10 ? 'rising' : datum.growth <= 0.058 ? 'flat' : 'mid'",
      "as": "tier"
    },
    {
      "calculate": "datum.state + '  ' + format(datum.adoption, '.0%')",
      "as": "left_label"
    }
  ],
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "axis": null
    },
    "y": {
      "field": "adoption",
      "type": "quantitative",
      "scale": {
        "domain": [
          0.4,
          0.95
        ]
      },
      "axis": null
    },
    "detail": {
      "field": "state"
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#4a4640",
        "strokeWidth": 1,
        "opacity": 0.1
      },
      "transform": [
        {
          "filter": "datum.state === 'Australian Capital Territory'"
        }
      ],
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "datum": 0.95,
          "type": "quantitative"
        },
        "y2": {
          "datum": 0.4
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.state === 'Australian Capital Territory'"
        }
      ],
      "mark": {
        "type": "text",
        "dy": -12,
        "fontSize": 11,
        "fontWeight": 600,
        "color": "#4a4640"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "datum": 0.95,
          "type": "quantitative"
        },
        "text": {
          "field": "year"
        }
      }
    },
    {
      "params": [
        {
          "name": "state_hover",
          "select": {
            "type": "point",
            "fields": [
              "state"
            ],
            "on": "pointerover",
            "clear": "pointerout"
          }
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "linear"
      },
      "encoding": {
        "color": {
          "field": "tier",
          "type": "nominal",
          "scale": {
            "domain": [
              "rising",
              "mid",
              "flat"
            ],
            "range": [
              "#de1e1c",
              "#4a4640",
              "#c9b5b0"
            ]
          },
          "legend": null
        },
        "opacity": {
          "condition": {
            "param": "state_hover",
            "empty": true,
            "value": 1
          },
          "value": 0.15
        },
        "strokeWidth": {
          "condition": {
            "param": "state_hover",
            "empty": false,
            "value": 3.5
          },
          "value": 2
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 50
      },
      "encoding": {
        "color": {
          "field": "tier",
          "type": "nominal",
          "scale": {
            "domain": [
              "rising",
              "mid",
              "flat"
            ],
            "range": [
              "#de1e1c",
              "#c9b5b0",
              "#d4cfc9"
            ]
          },
          "legend": null
        },
        "opacity": {
          "condition": {
            "param": "state_hover",
            "empty": true,
            "value": 1
          },
          "value": 0.15
        },
        "tooltip": [
          {
            "field": "state",
            "title": "State"
          },
          {
            "field": "adoption",
            "title": "Adoption rate",
            "format": ".0%"
          },
          {
            "field": "year",
            "title": "Year"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year === '2024'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -10,
        "fontSize": 9
      },
      "encoding": {
        "text": {
          "field": "left_label",
          "type": "nominal"
        },
        "color": {
          "field": "tier",
          "type": "nominal",
          "scale": {
            "domain": [
              "rising",
              "mid",
              "flat"
            ],
            "range": [
              "#de1e1c",
              "#9a9690",
              "#c0bbb5"
            ]
          },
          "legend": null
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year === '2028'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "fontSize": 9
      },
      "encoding": {
        "text": {
          "field": "adoption",
          "format": ".0%"
        },
        "color": {
          "field": "tier",
          "type": "nominal",
          "scale": {
            "domain": [
              "rising",
              "mid",
              "flat"
            ],
            "range": [
              "#de1e1c",
              "#9a9690",
              "#c0bbb5"
            ]
          },
          "legend": null
        }
      }
    }
  ]
}