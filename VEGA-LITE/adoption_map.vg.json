{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "autosize": { "type": "fit", "contains": "padding" },
  "background": "transparent",
  "config": {
    "font": "Helvetica Neue, Helvetica, Arial, sans-serif",
    "legend": {
      "labelColor": "#4a4640",
      "labelFontSize": 10,
      "titleColor": "#4a4640",
      "titleFontSize": 10,
      "titleFontWeight": "normal"
    },
    "view": { "stroke": null }
  },
  "projection": {
    "type": "albers",
    "rotate": [-132, 0, 0],
    "center": [0, -27],
    "parallels": [-18, -36],
    "scale": 520
  },
  "data": {
    "url": "../data/STE_2016_AUST.json",
    "format": {
      "type": "topojson",
      "feature": "STE_2016_AUST"
    }
  },
  "transform": [
    {
      "lookup": "properties.STE_NAME16",
      "from": {
        "data": { "url": "../data/AdoptionState.csv" },
        "key": "state",
        "fields": ["ai_adoption"]
      }
    }
  ],
  "layer": [
    {
      "params": [
        { "name": "state_hover", "select": { "type": "point", "on": "pointerover", "clear": "pointerout" } }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#f7f7f7",
        "strokeWidth": 1.5
      },
      "encoding": {
        "color": {
          "field": "ai_adoption",
          "type": "quantitative",
          "scale": {
            "domain": [0.4, 0.8],
            "range": ["#d4cfc9", "#1a1814"]
          },
          "legend": {
            "title": "AI Adoption Rate",
            "format": ".0%",
            "orient": "top-right",
            "offset": 8
          }
        },
        "stroke": {
          "condition": { "param": "state_hover", "empty": false, "value": "#de1e1c" },
          "value": "#f7f7f7"
        },
        "strokeWidth": {
          "condition": { "param": "state_hover", "empty": false, "value": 2.5 },
          "value": 1.5
        },
        "tooltip": [
          { "field": "properties.STE_NAME16", "type": "nominal", "title": "State" },
          { "field": "ai_adoption", "type": "quantitative", "title": "AI Adoption", "format": ".0%" }
        ]
      }
    }
  ]
}
