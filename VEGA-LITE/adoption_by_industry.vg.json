{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 700,
  "height": 380,
  "autosize": {"type": "fit"},
  "background": "transparent",

  "data": [
    {
      "name": "table",
      "url": "../data/adoption_by_industry.csv",
      "format": {"type": "csv", "parse": {"adopting": "number", "not_adopting": "number", "not_aware": "number"}},
      "transform": [
        {
          "type": "formula",
          "as": "not_aware_start",
          "expr": "-(datum.not_aware + datum.not_adopting / 2)"
        },
        {
          "type": "formula",
          "as": "not_aware_end",
          "expr": "-(datum.not_adopting / 2)"
        },
        {
          "type": "formula",
          "as": "not_adopting_start",
          "expr": "-(datum.not_adopting / 2)"
        },
        {
          "type": "formula",
          "as": "not_adopting_end",
          "expr": "datum.not_adopting / 2"
        },
        {
          "type": "formula",
          "as": "adopting_start",
          "expr": "datum.not_adopting / 2"
        },
        {
          "type": "formula",
          "as": "adopting_end",
          "expr": "datum.not_adopting / 2 + datum.adopting"
        }
      ]
    },
    {
      "name": "sorted",
      "source": "table",
      "transform": [
        {"type": "collect", "sort": {"field": "adopting", "order": "descending"}}
      ]
    }
  ],

  "scales": [
    {
      "name": "y",
      "type": "band",
      "domain": {"data": "sorted", "field": "industry"},
      "range": "height",
      "padding": 0.3
    },
    {
      "name": "x",
      "type": "linear",
      "domain": [-70, 70],
      "range": "width",
      "nice": true
    }
  ],

  "axes": [
    {
      "orient": "bottom",
      "scale": "x",
      "tickCount": 7,
      "labelColor": "#9a9690",
      "labelFontSize": 10,
      "domainColor": "#e0dbd4",
      "tickColor": "#e0dbd4",
      "gridColor": "#e0dbd4",
      "grid": true,
      "title": "Adoption Rate",
      "encode": {
        "labels": {
          "update": {
            "text": {"signal": "abs(datum.value) + '%'"}
          }
        }
      }
    }
  ],

  "signals": [
    {
      "name": "hovered", "value": null,
      "on": [
        { "events": "rect:pointerover", "update": "datum.industry" },
        { "events": "rect:pointerout",  "update": "null" }
      ]
    }
  ],

  "marks": [
    {
      "type": "text",
      "from": {"data": "sorted"},
      "encode": {
        "enter": {
          "x": {"value": -8},
          "y": {"scale": "y", "field": "industry", "band": 0.5},
          "text": {"field": "industry"},
          "align": {"value": "right"},
          "baseline": {"value": "middle"},
          "fontSize": {"value": 11}
        },
        "update": {
          "fill": {"signal": "hovered === datum.industry ? '#1a1814' : '#4a4640'"},
          "fontWeight": {"signal": "hovered === datum.industry ? 700 : 400"}
        }
      }
    },
    {
      "type": "rect",
      "from": {"data": "sorted"},
      "encode": {
        "enter": {
          "y": {"scale": "y", "field": "industry"},
          "height": {"scale": "y", "band": 1},
          "x": {"scale": "x", "field": "not_aware_start"},
          "x2": {"scale": "x", "field": "not_aware_end"},
          "tooltip": {"signal": "{'Industry': datum.industry, 'Not aware': datum.not_aware + '%', 'Not adopting': datum.not_adopting + '%', 'Adopting': datum.adopting + '%'}"}
        },
        "update": {
          "fill": {"value": "#d4cfc9"},
          "opacity": {"signal": "hovered === null || hovered === datum.industry ? 1 : 0.35"}
        }
      }
    },
    {
      "type": "rect",
      "from": {"data": "sorted"},
      "encode": {
        "enter": {
          "y": {"scale": "y", "field": "industry"},
          "height": {"scale": "y", "band": 1},
          "x": {"scale": "x", "field": "not_adopting_start"},
          "x2": {"scale": "x", "field": "not_adopting_end"},
          "tooltip": {"signal": "{'Industry': datum.industry, 'Not aware': datum.not_aware + '%', 'Not adopting': datum.not_adopting + '%', 'Adopting': datum.adopting + '%'}"}
        },
        "update": {
          "fill": {"value": "#9a9690"},
          "opacity": {"signal": "hovered === null || hovered === datum.industry ? 1 : 0.35"}
        }
      }
    },
    {
      "type": "rect",
      "from": {"data": "sorted"},
      "encode": {
        "enter": {
          "y": {"scale": "y", "field": "industry"},
          "height": {"scale": "y", "band": 1},
          "x": {"scale": "x", "field": "adopting_start"},
          "x2": {"scale": "x", "field": "adopting_end"},
          "tooltip": {"signal": "{'Industry': datum.industry, 'Not aware': datum.not_aware + '%', 'Not adopting': datum.not_adopting + '%', 'Adopting': datum.adopting + '%'}"}
        },
        "update": {
          "fill": {"value": "#de1e1c"},
          "opacity": {"signal": "hovered === null || hovered === datum.industry ? 1 : 0.35"}
        }
      }
    },
    {
      "type": "rule",
      "encode": {
        "enter": {
          "x": {"scale": "x", "value": 0},
          "y": {"value": 0},
          "y2": {"field": {"group": "height"}},
          "stroke": {"value": "#1a1814"},
          "strokeWidth": {"value": 1},
          "strokeDash": {"value": [4, 3]}
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "enter": {
          "x": {"scale": "x", "value": -33},
          "y": {"scale": "y", "value": "Distribution", "band": -3},
          "text": {"value": "← Don't know AI is an option"},
          "align": {"value": "center"},
          "fontSize": {"value": 8},
          "fontStyle": {"value": "italic"},
          "fill": {"value": "#d4cfc9"},
          "fontWeight": {"value": "bold"}
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "enter": {
          "x": {"scale": "x", "value": 33},
          "y": {"scale": "y", "value": "Distribution", "band": -3},
          "text": {"value": "Using AI →"},
          "align": {"value": "center"},
          "fontSize": {"value": 8},
          "fontStyle": {"value": "italic"},
          "fill": {"value": "#de1e1c"},
          "fontWeight": {"value": "bold"}
        }
      }
    }
  ]
}
