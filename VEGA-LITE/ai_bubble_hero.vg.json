{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 650,
  "height": 1100,
  "padding" : {"top": 0,"left": 0},
  "autosize": {"type": "fit", "contains": "padding"},
  "signals": [
    {"name": "cx", "update": "width / 2"},
    {"name": "cy", "update": "height / 2"},
    {"name": "gravityX", "value": 0.7},
    {"name": "gravityY", "value": 0.4}
  ],
  "data": [
    {
      "name": "table",
      "url": "../data/ai_companies_by_state.csv",
      "format": {
        "type": "csv",
        "parse": {"ai_companies": "number", "ai_adoption": "number"}
      },
      "transform": [{"type": "filter", "expr": "datum.ai_companies > 0"}]
    }
  ],
  "scales": [
    {
      "name": "size",
      "type": "linear",
      "domain": {"data": "table", "field": "ai_companies"},
      "range": [550, 115000]
    }
  ],
  "marks": [
    {
      "name": "nodes",
      "type": "symbol",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "fill": {"value": "#de1e1c"},
          "xfocus": {"signal": "cx"},
          "yfocus": {"signal": "cy"}
        },
        "update": {
          "size": {"field": "ai_companies", "scale": "size"},
          "tooltip": {
            "signal": "{'State': datum.state, 'AI companies': datum.ai_companies, 'AI adoption': format(datum.ai_adoption, '.0%')}"
          }
        }
      },
      "transform": [
        {
          "type": "force",
          "iterations": 100,
          "static": true,
          "forces": [
            {
              "force": "collide",
              "iterations": 2,
              "radius": {"expr": "sqrt(datum.size / PI) + 5"}
            },
            {"force": "center", "x": {"signal": "cx"}, "y": {"signal": "cy"}},
            {"force": "x", "x": "xfocus", "strength": {"signal": "gravityX"}},
            {"force": "y", "y": "yfocus", "strength": {"signal": "gravityY"}}
          ]
        }
      ]
    },
    {
      "type": "text",
      "from": {"data": "nodes"},
      "encode": {
        "enter": {
          "align": {"value": "center"},
          "baseline": {"value": "bottom"},
          "font": {"value": "Helvetica Neue, Helvetica, Arial, sans-serif"},
          "fontSize": {"signal": "max(11, sqrt(datum.size) / 8)"},
          "fontWeight": {"value": 900},
          "fill": {"value": "#FFFFFF"},
          "text": {"field": "datum.state_code"}
        },
        "update": {
          "x": {"field": "x"}, 
          "y": {"signal": "datum.y"}}
      }
    },
    {
      "type": "text",
      "from": {"data": "nodes"},
      "encode": {
        "enter": {
          "align": {"value": "center"},
          "baseline": {"value": "top"},
          "font": {"value": "Helvetica Neue, Helvetica, Arial, sans-serif"},
          "fontWeight" : {"value": 500},
          "fontSize": {"signal": "max(11, sqrt(datum.size) / 12)"},
          "fill": {"value": "#FBE7DD"},
          "text": {"field": "datum.ai_companies"}
        },
        "update": {
          "x": {"field": "x"},
          "y": {"signal": "datum.y + 3"}
        }
      }
    }
  ]
}
