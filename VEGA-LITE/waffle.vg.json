  "layer": [
    {
      "comment": "Waffle squares",
      "params": [
        {
          "name": "sq_hover",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout"
          }
        }
      ],
      "mark": {
        "type": "rect",
        "cornerRadius": 2
      },
      "encoding": {
        "x": {
          "field": "col",
          "type": "ordinal",
          "axis": null
        },
        "y": {
          "field": "row",
          "type": "ordinal",
          "axis": null,
          "sort": "descending"
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": [
              "Adopting AI",
              "Not adopting"
            ],
            "range": [
              "#de1e1c",
              "#e0dbd4"
            ]
          },
          "legend": {
            "title": null,
            "orient": "bottom",
            "direction": "horizontal",
            "labelFontSize": 9,
            "labelColor": "#4a4640",
            "symbolStrokeWidth": 0,
            "symbolSize": 80
          }
        },
        "opacity": {
          "condition": [
            {
              "test": "datum.is_you === 'yes'",
              "value": 1
            },
            {
              "param": "sq_hover",
              "empty": false,
              "value": 1
            }
          ],
          "value": 0.75
        },
        "strokeWidth": {
          "condition": {
            "param": "sq_hover",
            "empty": false,
            "value": 2
          },
          "value": 0
        },
        "stroke": {
          "condition": {
            "param": "sq_hover",
            "empty": false,
            "value": "#1a1814"
          },
          "value": "transparent"
        },
        "tooltip": [
          {
            "field": "category",
            "title": "Status"
          },
          {
            "field": "id",
            "title": "Business #"
          }
        ]
      }
    },
    {
      "comment": "YOU label on square 26",
      "transform": [
        {
          "filter": "datum.is_you === 'yes'"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 7,
        "fontWeight": "bold",
        "color": "white",
        "baseline": "middle",
        "align": "center"
      },
      "encoding": {
        "x": {
          "field": "col",
          "type": "ordinal"
        },
        "y": {
          "field": "row",
          "type": "ordinal",
          "sort": "descending"
        },
        "text": {
          "value": "YOU?"
        }
      }
    }
  ]
